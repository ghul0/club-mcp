# Base club URL. Default and primary target is https://club.hyperhuman.pl
HHC_BASE_URL=https://club.hyperhuman.pl

# Comma-separated allowlist for self-hosted deployments.
HHC_ALLOWED_BASE_URLS=https://club.hyperhuman.pl

# Must remain true for v1.
HHC_READ_ONLY=true

# Allowed: trace, debug, info, warn, error.
HHC_LOG_LEVEL=info

# Hosted rate limits. Local stdio may ignore these.
HHC_RATE_LIMIT_PER_MCP_USER_PER_MINUTE=60
HHC_RATE_LIMIT_PER_WP_USER_PER_MINUTE=120
HHC_RECENT_COMMENT_SCANS_PER_USER_PER_HOUR=10
HHC_MAX_UPSTREAM_CONCURRENCY=4

# Local stdio env auth. Prefer OS keyring after hhc-mcp login.
HHC_USER=
HHC_APP_PASS=

# Allowed: oauth, cloudflare_access, private_headers.
HHC_AUTH_MODE=oauth

# Public URL of the hosted HTTP MCP server.
HHC_PUBLIC_URL=https://mcp.example.com

# Keycloak/OIDC values for hosted public OAuth mode.
HHC_OAUTH_ISSUER=
HHC_OAUTH_AUDIENCE=
HHC_OAUTH_JWKS_URL=

# Allowed: disabled, postgres_envelope.
HHC_CREDENTIAL_STORE=disabled

# Secret reference for the key-encryption key. The raw key must not live in the database.
HHC_ENCRYPTION_KEY_REF=

# Optional Cloudflare Access private edge mode.
CLOUDFLARE_TEAM_DOMAIN=
CLOUDFLARE_POLICY_AUD=

# Optional hosted observability.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
