{
  "name": "@hhc-mcp/core",
  "version": "0.1.1",
  "description": "Framework-agnostic core library: GET-only HTTP client, Zod envelopes, and 13 read-only operations for the Hyper Human Club / Fluent Community REST API.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hyper-human-club",
    "fluent-community",
    "wordpress",
    "rest-api",
    "read-only",
    "zod",
    "typescript"
  ],
  "homepage": "https://github.com/ghul0/club-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghul0/club-mcp.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ghul0/club-mcp/issues"
  },
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
