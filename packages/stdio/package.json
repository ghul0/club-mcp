{
  "name": "@hhc-mcp/stdio",
  "version": "0.1.0",
  "description": "Local stdio Model Context Protocol (MCP) server exposing 13 read-only Hyper Human Club tools to Claude Desktop, Cursor, and any MCP-compliant client.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "stdio",
    "claude-desktop",
    "cursor",
    "hyper-human-club",
    "fluent-community",
    "wordpress",
    "read-only",
    "typescript"
  ],
  "homepage": "https://github.com/ghul0/club-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghul0/club-mcp.git",
    "directory": "packages/stdio"
  },
  "bugs": {
    "url": "https://github.com/ghul0/club-mcp/issues"
  },
  "type": "module",
  "license": "MIT",
  "bin": {
    "hhc-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hhc-mcp/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
